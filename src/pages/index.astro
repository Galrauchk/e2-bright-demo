---
import Layout from '../layouts/Layout.astro';

const homeSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Cabinet Santé Lyon",
      "url": "https://e2-bright-demo.netlify.app"
    },
    {
      "@type": "MedicalBusiness",
      "@id": "https://e2-bright-demo.netlify.app/#business",
      "name": "Cabinet Santé Lyon",
      "description": "Kinésithérapie & Ostéopathie à Lyon 6ème",
      "url": "https://e2-bright-demo.netlify.app",
      "telephone": "+33472112233",
      "email": "contact@cabinet-sante-lyon.fr",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Lyon 6ème",
        "addressLocality": "Lyon",
        "postalCode": "69006",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "45.7676",
        "longitude": "4.8467"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "19:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday"],
          "opens": "09:00",
          "closes": "13:00"
        }
      ],
      "medicalSpecialty": ["PhysicalTherapy", "Osteopathic"],
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": 3 },
      "priceRange": "€€",
      "image": "https://e2-bright-demo.netlify.app/favicon.svg",
      "sameAs": []
    }
  ]
};
---

<Layout
  title="Cabinet Santé Lyon — Kinésithérapie & Ostéopathie à Lyon 6ème"
  description="Cabinet de kinésithérapie et ostéopathie à Lyon 6ème. 3 praticiens expérimentés, rendez-vous sous 48h, mutuelle acceptée. Appelez le 04 72 11 22 33."
  currentPage="/"
  schema={homeSchema}
>
  <!-- ═══════════════════════════════════════
       HERO — Split Layout
  ═══════════════════════════════════════ -->
  <section class="hero" aria-label="Présentation du cabinet">
    <div class="container">
      <div class="hero-grid">

        <!-- Left: Content -->
        <div class="hero-content">
          <span class="hero-label">CABINET MÉDICAL · LYON 6ÈME</span>

          <h1>Votre bien-être,<br />notre expertise</h1>

          <p class="hero-subtitle">
            Kinésithérapie, ostéopathie et rééducation au cœur de Lyon.
            Une approche globale et personnalisée pour retrouver mobilité, confort et vitalité.
          </p>

          <div class="hero-buttons">
            <a href="/contact" class="btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z"/></svg>
              Prendre rendez-vous
            </a>
            <a href="/services" class="btn-secondary">
              Nos soins
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <div class="hero-badges">
            <span class="badge">✓ 3 praticiens</span>
            <span class="badge">✓ Rdv sous 48h</span>
            <span class="badge">✓ Mutuelle acceptée</span>
          </div>
        </div>

        <!-- Right: Illustration -->
        <div class="hero-visual" aria-hidden="true">
          <div class="hero-bg-circle"></div>

          <!-- Abstract wellness illustration -->
          <div class="hero-illustration">
            <svg viewBox="0 0 440 460" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Illustration cabinet médical">
              <defs>
                <linearGradient id="g1" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#00e5ff"/>
                  <stop offset="100%" stop-color="#0066ff"/>
                </linearGradient>
                <linearGradient id="g2" x1="100%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.6"/>
                  <stop offset="100%" stop-color="#0066ff" stop-opacity="0.4"/>
                </linearGradient>
              </defs>

              <!-- Big outer circle -->
              <circle cx="220" cy="230" r="190" fill="url(#g1)" opacity="0.07"/>
              <circle cx="220" cy="230" r="150" fill="url(#g1)" opacity="0.06"/>

              <!-- Human figure — wellness pose (arms slightly raised) -->
              <!-- Head -->
              <circle cx="220" cy="110" r="44" fill="url(#g1)" opacity="0.9"/>

              <!-- Neck -->
              <rect x="211" y="152" width="18" height="20" rx="9" fill="url(#g1)" opacity="0.85"/>

              <!-- Torso -->
              <path d="M180 175 Q220 168 260 175 L268 295 Q220 305 172 295 Z" fill="url(#g1)" opacity="0.88"/>

              <!-- Left arm -->
              <path d="M183 185 Q158 195 138 218 Q128 230 130 242 Q134 255 146 250 Q160 244 168 228 L183 205" fill="url(#g1)" opacity="0.78"/>

              <!-- Right arm -->
              <path d="M257 185 Q282 195 302 218 Q312 230 310 242 Q306 255 294 250 Q280 244 272 228 L257 205" fill="url(#g1)" opacity="0.78"/>

              <!-- Left leg -->
              <path d="M193 295 Q188 330 184 368 Q182 380 193 382 Q205 382 207 370 L212 295" fill="url(#g1)" opacity="0.82"/>

              <!-- Right leg -->
              <path d="M247 295 Q252 330 256 368 Q258 380 247 382 Q235 382 233 370 L228 295" fill="url(#g1)" opacity="0.82"/>

              <!-- Decorative elements -->
              <!-- Top right circle -->
              <circle cx="368" cy="88" r="28" fill="url(#g2)" opacity="0.5"/>
              <circle cx="368" cy="88" r="16" fill="url(#g1)" opacity="0.25"/>

              <!-- Bottom left circle -->
              <circle cx="72" cy="360" r="22" fill="url(#g2)" opacity="0.4"/>

              <!-- Medical cross — top left -->
              <rect x="54" y="150" width="38" height="10" rx="5" fill="url(#g1)" opacity="0.4"/>
              <rect x="74" y="130" width="10" height="38" rx="5" fill="url(#g1)" opacity="0.4"/>

              <!-- EKG / heartbeat line -->
              <polyline
                points="295,310 312,310 320,288 332,332 342,296 352,296 360,310 378,310"
                stroke="url(#g1)"
                stroke-width="3"
                fill="none"
                opacity="0.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              />

              <!-- Floating dots -->
              <circle cx="145" cy="72" r="7" fill="#00e5ff" opacity="0.45"/>
              <circle cx="392" cy="220" r="9" fill="#0066ff" opacity="0.25"/>
              <circle cx="62" cy="240" r="5" fill="#00e5ff" opacity="0.35"/>
              <circle cx="380" cy="370" r="6" fill="#00e5ff" opacity="0.3"/>
            </svg>
          </div>

          <!-- Floating rating card -->
          <div class="hero-rating-card">
            <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#00e5ff,#0066ff);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <div class="rating-info">
              <span class="rating-score">⭐ 4.9 / 5</span>
              <span class="rating-count">200+ patients satisfaits</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       SERVICES — 6 Cards
  ═══════════════════════════════════════ -->
  <section class="section" id="soins" aria-label="Nos soins">
    <div class="container">
      <div class="services-header">
        <span class="label">NOS SOINS</span>
        <h2 class="section-title">Des soins adaptés à vos besoins</h2>
        <p class="section-subtitle text-center" style="margin:0 auto;">
          Notre équipe pluridisciplinaire vous accompagne avec des techniques éprouvées
          et une approche centrée sur votre rétablissement.
        </p>
      </div>

      <div class="services-grid">

        <!-- 1. Kinésithérapie -->
        <article class="service-card">
          <div class="icon-circle">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="5" r="2"/>
              <path d="M12 7v6l3 3M9 13l-3 3M12 13v6"/>
              <path d="M9 10H6M18 10h-3"/>
            </svg>
          </div>
          <h3>Kinésithérapie</h3>
          <p>Traitement des douleurs musculosquelettiques, rééducation post-opératoire et prévention des blessures grâce à des techniques manuelles et instrumentales adaptées à chaque patient.</p>
          <a href="/services#kinesitherapie" class="service-link">
            En savoir plus
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <!-- 2. Ostéopathie -->
        <article class="service-card">
          <div class="icon-circle">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 11V9a6 6 0 00-12 0v2"/>
              <path d="M6 11h12v4a6 6 0 01-12 0v-4z"/>
              <path d="M10 15a2 2 0 004 0"/>
            </svg>
          </div>
          <h3>Ostéopathie</h3>
          <p>Approche globale du corps par des manipulations douces et précises visant à restaurer l'équilibre musculosquelettique, viscéral et crânien pour améliorer votre qualité de vie.</p>
          <a href="/services#osteopathie" class="service-link">
            En savoir plus
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <!-- 3. Rééducation -->
        <article class="service-card">
          <div class="icon-circle">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3>Rééducation</h3>
          <p>Programme de rééducation fonctionnelle personnalisé post-traumatisme ou post-chirurgie. Récupération progressive de la mobilité, de la force et de l'autonomie par étapes.</p>
          <a href="/services#reeducation" class="service-link">
            En savoir plus
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <!-- 4. Massage thérapeutique -->
        <article class="service-card">
          <div class="icon-circle">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 12c0-4.418 3.582-8 8-8s8 3.582 8 8-3.582 8-8 8"/>
              <path d="M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4"/>
              <circle cx="12" cy="12" r="1.5" fill="white" stroke="none"/>
            </svg>
          </div>
          <h3>Massage thérapeutique</h3>
          <p>Techniques de massage adaptées à des fins thérapeutiques : soulagement des tensions, amélioration de la circulation, réduction du stress et accompagnement de la récupération musculaire.</p>
          <a href="/services#massage" class="service-link">
            En savoir plus
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <!-- 5. Bilan postural -->
        <article class="service-card">
          <div class="icon-circle">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="2" x2="12" y2="22"/>
              <path d="M8 6l4-4 4 4"/>
              <path d="M8 18l4 4 4-4"/>
              <line x1="6" y1="12" x2="18" y2="12" stroke-dasharray="2 2"/>
            </svg>
          </div>
          <h3>Bilan postural</h3>
          <p>Analyse complète et précise de votre posture pour identifier les déséquilibres, les compensations et leurs conséquences. Établissement d'un programme de correction ciblé et durable.</p>
          <a href="/services#bilan" class="service-link">
            En savoir plus
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <!-- 6. Suivi personnalisé -->
        <article class="service-card">
          <div class="icon-circle">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
              <path d="M8 14l2 2 4-4"/>
            </svg>
          </div>
          <h3>Suivi personnalisé</h3>
          <p>Plan de suivi individualisé adapté à vos objectifs et à l'évolution de votre état. Coordination entre praticiens du cabinet pour une prise en charge complète et cohérente.</p>
          <a href="/services#suivi" class="service-link">
            En savoir plus
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       STATS BAR
  ═══════════════════════════════════════ -->
  <section class="stats-section" aria-label="Chiffres clés">
    <div class="container">
      <div class="stats-bar">
        <div>
          <div class="stat-number">3</div>
          <div class="stat-label">Praticiens experts</div>
        </div>
        <div>
          <div class="stat-number">200+</div>
          <div class="stat-label">Patients suivis</div>
        </div>
        <div>
          <div class="stat-number">48h</div>
          <div class="stat-label">Délai moyen RDV</div>
        </div>
        <div>
          <div class="stat-number">15 ans</div>
          <div class="stat-label">D'expérience cumulée</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       TESTIMONIALS
  ═══════════════════════════════════════ -->
  <section class="section" aria-label="Témoignages patients">
    <div class="container">
      <div class="testimonials-header">
        <span class="label">TÉMOIGNAGES</span>
        <h2 class="section-title">Ce que disent nos patients</h2>
        <p class="section-subtitle" style="margin:0 auto;">
          Des centaines de patients nous font confiance. Voici quelques témoignages.
        </p>
      </div>

      <div class="testimonials-grid">

        <div class="testimonial-card">
          <div class="t-stars">★★★★★</div>
          <p class="t-quote">
            "Après mon opération du genou, la rééducation avec le Dr Martin a été remarquable.
            Programme très bien adapté, progression régulière, et une vraie disponibilité pour
            répondre à toutes mes questions. Je recommande vivement ce cabinet."
          </p>
          <div class="t-author">
            <div class="t-avatar" aria-hidden="true">JP</div>
            <div>
              <div class="t-name">Jean-Pierre M.</div>
              <div class="t-role">Rééducation post-opératoire</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="t-stars">★★★★★</div>
          <p class="t-quote">
            "Des douleurs lombaires chroniques depuis 3 ans, et en quelques séances d'ostéopathie
            avec Sophie, une vraie amélioration. L'approche est douce, professionnelle et
            l'explication des techniques est très rassurante."
          </p>
          <div class="t-author">
            <div class="t-avatar" aria-hidden="true">MC</div>
            <div>
              <div class="t-name">Marie-Claire D.</div>
              <div class="t-role">Ostéopathie — Lombalgies</div>
            </div>
          </div>
        </div>

        <div class="testimonial-card">
          <div class="t-stars">★★★★★</div>
          <p class="t-quote">
            "Suivi pour une entorse de cheville. L'équipe est à l'écoute, le cabinet est
            moderne et agréable. Prise de rendez-vous facile en ligne, délai très court.
            Je suis retourné à la course à pied en 6 semaines. Merci à toute l'équipe !"
          </p>
          <div class="t-author">
            <div class="t-avatar" aria-hidden="true">AL</div>
            <div>
              <div class="t-name">Antoine L.</div>
              <div class="t-role">Kinésithérapie — Sportif</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════════ -->
  <section class="cta-section" aria-label="Prise de rendez-vous">
    <div class="cta-deco" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <span class="label">PRENDRE RENDEZ-VOUS</span>
      <h2>Prêt à prendre soin de vous ?</h2>
      <p>
        Consultez l'un de nos 3 praticiens expérimentés à Lyon 6ème.
        Rendez-vous disponibles sous 48h, mutuelle acceptée.
      </p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z"/></svg>
          Prendre rendez-vous
        </a>
        <a href="tel:0472112233" class="btn-primary" style="background:white;color:#0a0f1e;box-shadow:0 4px 16px rgba(0,0,0,0.08);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 012 1.18 2 2 0 014 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 7.91A16 16 0 0016 15.91l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0124 16z"/></svg>
          04 72 11 22 33
        </a>
      </div>
    </div>
  </section>
</Layout>
