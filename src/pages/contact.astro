---
import Layout from '../layouts/Layout.astro';

const faqItems = [
  {
    q: "Comment prendre rendez-vous au Cabinet Santé Lyon ?",
    a: "Vous pouvez prendre rendez-vous par téléphone au 04 72 11 22 33 du lundi au vendredi de 8h à 19h et le samedi de 9h à 13h. Vous pouvez également utiliser notre formulaire de contact en ligne et nous vous rappellerons dans les 2 heures ouvrées."
  },
  {
    q: "Dois-je avoir une ordonnance pour consulter un kinésithérapeute ?",
    a: "Oui, une prescription médicale (ordonnance) est généralement nécessaire pour bénéficier du remboursement par la Sécurité Sociale. Cependant, une première consultation sans ordonnance est possible pour évaluer votre situation. Votre médecin traitant peut ensuite établir la prescription adaptée."
  },
  {
    q: "L'ostéopathie est-elle remboursée par la Sécurité Sociale ?",
    a: "L'ostéopathie n'est pas remboursée par la Sécurité Sociale, mais de nombreuses mutuelles et complémentaires santé prennent en charge tout ou partie des consultations (généralement 1 à 4 séances par an). Renseignez-vous auprès de votre mutuelle pour connaître votre niveau de remboursement."
  },
  {
    q: "Quel est le délai pour obtenir un rendez-vous ?",
    a: "Nous nous efforçons de vous proposer un rendez-vous sous 48 heures pour les demandes standard. Pour les urgences (suite à un accident, une chute ou une douleur aiguë), nous réservons des créneaux d'urgence disponibles en journée. Appelez-nous directement pour les situations urgentes."
  },
  {
    q: "Quels sont vos horaires d'ouverture et où êtes-vous situés ?",
    a: "Le cabinet est ouvert du lundi au vendredi de 8h à 19h et le samedi de 9h à 13h. Nous sommes situés à Lyon 6ème (69006), facilement accessible en transports en commun (métro, bus) et avec un parking à proximité. Contactez-nous pour l'adresse précise."
  },
  {
    q: "Proposez-vous des soins à domicile pour les personnes à mobilité réduite ?",
    a: "Oui, nous pouvons intervenir à domicile pour les patients présentant des difficultés de déplacement (personnes âgées, handicap moteur, suite d'opération). Ce service est soumis à prescription médicale et des conditions tarifaires spécifiques s'appliquent. Contactez-nous pour en discuter."
  }
];

const contactSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalBusiness",
      "@id": "https://e2-bright-demo.netlify.app/#business",
      "name": "Cabinet Santé Lyon",
      "telephone": "+33472112233",
      "email": "contact@cabinet-sante-lyon.fr"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    }
  ]
};
---

<Layout
  title="Contact & Rendez-vous — Cabinet Santé Lyon | Lyon 6ème"
  description="Prenez rendez-vous au Cabinet Santé Lyon. Kinésithérapie et ostéopathie à Lyon 6ème. Disponibilité sous 48h, mutuelle acceptée. Tél : 04 72 11 22 33."
  currentPage="/contact"
  schema={contactSchema}
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="label">CONTACT</span>
      <h1>Prenez rendez-vous</h1>
      <p>
        Notre équipe est disponible du lundi au vendredi de 8h à 19h
        et le samedi matin. Rendez-vous sous 48h garantis.
      </p>
    </div>
  </section>

  <!-- Contact Layout -->
  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <!-- Left: Info -->
        <div>
          <h3 style="font-size:1.375rem;font-weight:700;color:var(--navy);margin-bottom:2rem;">Informations pratiques</h3>

          <div class="contact-item">
            <div class="c-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0066ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 012 1.18 2 2 0 014 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 7.91A16 16 0 0016 15.91l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0124 16z"/></svg>
            </div>
            <div>
              <div class="c-label">Téléphone</div>
              <div class="c-value"><a href="tel:0472112233">04 72 11 22 33</a></div>
            </div>
          </div>

          <div class="contact-item">
            <div class="c-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0066ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <div class="c-label">Email</div>
              <div class="c-value"><a href="mailto:contact@cabinet-sante-lyon.fr">contact@cabinet-sante-lyon.fr</a></div>
            </div>
          </div>

          <div class="contact-item">
            <div class="c-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0066ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <div class="c-label">Adresse</div>
              <div class="c-value">Lyon 6ème<br/><span style="font-size:0.875rem;color:var(--text-sm);">69006 Lyon — Proche métro</span></div>
            </div>
          </div>

          <!-- Hours -->
          <div style="margin-top:2rem;padding:1.75rem;background:var(--bg-light);border-radius:1.25rem;">
            <h4 style="font-size:1rem;font-weight:600;color:var(--navy);margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0066ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Horaires d'ouverture
            </h4>
            <div class="hours-grid">
              <span class="hours-day">Lundi</span>      <span class="hours-time">8h00 – 19h00</span>
              <span class="hours-day">Mardi</span>      <span class="hours-time">8h00 – 19h00</span>
              <span class="hours-day">Mercredi</span>   <span class="hours-time">8h00 – 19h00</span>
              <span class="hours-day">Jeudi</span>      <span class="hours-time">8h00 – 19h00</span>
              <span class="hours-day">Vendredi</span>   <span class="hours-time">8h00 – 19h00</span>
              <span class="hours-day">Samedi</span>     <span class="hours-time">9h00 – 13h00</span>
              <span class="hours-day">Dimanche</span>   <span class="hours-time" style="color:#9ca3af;">Fermé</span>
            </div>
          </div>

          <!-- Badges -->
          <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:0.75rem;">
            <span class="badge">✓ Mutuelle acceptée</span>
            <span class="badge">✓ Carte vitale</span>
            <span class="badge">✓ Tiers payant</span>
            <span class="badge">✓ Accès PMR</span>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="contact-form-card">
          <h3>Envoyer une demande</h3>

          <form
            name="contact-cabinet"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            action="/contact?success=true"
          >
            <input type="hidden" name="form-name" value="contact-cabinet" />
            <p style="display:none;"><label>Ne remplissez pas ce champ : <input name="bot-field" /></label></p>

            <div class="form-row">
              <div class="form-group">
                <label for="prenom" class="form-label">Prénom <span style="color:#ef4444;">*</span></label>
                <input type="text" id="prenom" name="prenom" class="form-input" placeholder="Marie" required />
              </div>
              <div class="form-group">
                <label for="nom" class="form-label">Nom <span style="color:#ef4444;">*</span></label>
                <input type="text" id="nom" name="nom" class="form-input" placeholder="Dupont" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email <span style="color:#ef4444;">*</span></label>
              <input type="email" id="email" name="email" class="form-input" placeholder="marie.dupont@email.fr" required />
            </div>

            <div class="form-group">
              <label for="telephone" class="form-label">Téléphone</label>
              <input type="tel" id="telephone" name="telephone" class="form-input" placeholder="06 12 34 56 78" />
            </div>

            <div class="form-group">
              <label for="soin" class="form-label">Type de soin souhaité <span style="color:#ef4444;">*</span></label>
              <select id="soin" name="soin" class="form-select" required>
                <option value="" disabled selected>Choisir un soin…</option>
                <option value="kinesitherapie">Kinésithérapie</option>
                <option value="osteopathie">Ostéopathie</option>
                <option value="reeducation">Rééducation</option>
                <option value="massage">Massage thérapeutique</option>
                <option value="bilan">Bilan postural</option>
                <option value="suivi">Suivi personnalisé</option>
                <option value="autre">Autre / Non défini</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Votre message</label>
              <textarea id="message" name="message" class="form-textarea" placeholder="Décrivez brièvement votre situation ou vos questions…"></textarea>
            </div>

            <div class="form-checkbox-group">
              <input type="checkbox" id="rgpd" name="rgpd" required />
              <label for="rgpd">
                J'accepte que mes données soient utilisées pour traiter ma demande de rendez-vous,
                conformément à notre <a href="/mentions-legales" style="color:var(--blue);">politique de confidentialité</a>. <span style="color:#ef4444;">*</span>
              </label>
            </div>

            <button type="submit" class="btn-primary" style="width:100%;justify-content:center;font-size:1rem;padding:1rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              Envoyer ma demande
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- Map placeholder -->
  <section style="padding:0 0 6rem;">
    <div class="container">
      <div style="background:var(--bg-light);border-radius:1.5rem;height:300px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1rem;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0066ff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <p style="color:var(--text-sm);font-size:0.9375rem;text-align:center;">
          <strong style="color:var(--navy);">Cabinet Santé Lyon</strong><br/>
          Lyon 6ème, 69006 · Proche métro Foch
        </p>
        <a
          href="https://maps.google.com/?q=Lyon+6,+69006"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          style="font-size:0.875rem;padding:0.625rem 1.25rem;"
        >
          Ouvrir dans Google Maps →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section" style="background:var(--bg-light);">
    <div class="container">
      <div class="faq-header">
        <span class="label">FAQ</span>
        <h2 class="section-title">Questions fréquentes</h2>
        <p class="section-subtitle" style="margin:0 auto;">
          Tout ce que vous devez savoir avant votre première consultation.
        </p>
      </div>

      <div class="faq-list">
        {faqItems.map(item => (
          <div class="faq-item">
            <p class="faq-q">{item.q}</p>
            <p class="faq-a">{item.a}</p>
          </div>
        ))}
      </div>

      <div style="text-align:center;margin-top:3rem;">
        <p style="font-size:0.9375rem;color:var(--text-sm);margin-bottom:1.25rem;">
          Vous ne trouvez pas la réponse à votre question ?
        </p>
        <a href="tel:0472112233" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 012 1.18 2 2 0 014 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 7.91A16 16 0 0016 15.91l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0124 16z"/></svg>
          Appelez-nous : 04 72 11 22 33
        </a>
      </div>
    </div>
  </section>

</Layout>
